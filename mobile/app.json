{
  "expo": {
    "name": "Dominó Real RD",
    "slug": "domino-real-rd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#002D62"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dominorealrd.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Para cambiar tu foto de perfil",
        "NSCameraUsageDescription": "Para tu foto de perfil"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#002D62"
      },
      "package": "com.dominorealrd.app",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": { "compileSdkVersion": 34, "targetSdkVersion": 34 },
          "ios": { "deploymentTarget": "13.0" }
        }
      ]
    ],
    "extra": {
      "eas": { "projectId": "domino-real-rd" }
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#002D62",
      "androidMode": "default",
      "androidCollapsedTitle": "Dominó Real RD"
    }
  }
}
