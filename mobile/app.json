{
  "expo": {
    "name": "Dominó Real RD",
    "slug": "domino-real-rd",
    "version": "1.0.0",
    "scheme": "dominorealrd",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#002D62"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dominorealrd.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Para cambiar tu foto de perfil",
        "NSCameraUsageDescription": "Para tu foto de perfil"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#002D62"
      },
      "package": "com.dominorealrd.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "INTERNET",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#002D62",
          "defaultChannel": "domino_global",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 21
          },
          "ios": { "deploymentTarget": "13.0" }
        }
      ]
    ],
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#002D62",
      "androidMode": "default",
      "androidCollapsedTitle": "Dominó Real RD"
    },
    "extra": {
      "eas": {
        "projectId": "domino-real-rd"
      },
      "firebaseProjectId": "domino-realrd",
      "firebaseProjectNumber": "898063876162",
      "servidorUrl": "https://domino-real-rd-production.up.railway.app"
    },
    "owner": "dominorealrd"
  }
}
